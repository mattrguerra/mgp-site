---
import '@/styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Matt Guerra Photography',
  description = 'Commercial photography in Houston, Texas. Menu photography, product photography, portraits, and events.',
  ogImage = '/og-default.jpg',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const fullTitle = title === 'Matt Guerra Photography' ? title : `${title} | Matt Guerra Photography`;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Google Fonts: Instrument Sans, Work Sans, DM Mono -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400&family=Instrument+Sans:wght@600;700&family=Work+Sans:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen flex flex-col">
    <nav class="fixed top-0 w-full z-50 bg-bone/90 backdrop-blur-sm border-b border-warm-gray/10">
      <div class="container-wide flex items-center justify-between h-16 lg:h-20">
        <a href="/" class="font-display font-bold text-lg text-obsidian tracking-tight hover:text-copper">
          Matt Guerra
        </a>
        <div class="hidden md:flex items-center gap-8">
          <a href="/work" class="font-body text-sm text-slate hover:text-obsidian">Work</a>
          <a href="/pricing" class="font-body text-sm text-slate hover:text-obsidian">Pricing</a>
          <a href="/blog" class="font-body text-sm text-slate hover:text-obsidian">Blog</a>
          <a href="/about" class="font-body text-sm text-slate hover:text-obsidian">About</a>
          <a href="/book" class="btn-primary text-xs">Book a Session</a>
        </div>
        <button
          id="mobile-menu-toggle"
          class="md:hidden p-2 text-obsidian"
          aria-label="Toggle menu"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
      <!-- Mobile menu -->
      <div id="mobile-menu" class="hidden md:hidden border-t border-warm-gray/10 bg-bone">
        <div class="container-wide py-4 flex flex-col gap-4">
          <a href="/work" class="font-body text-sm text-slate hover:text-obsidian py-2">Work</a>
          <a href="/pricing" class="font-body text-sm text-slate hover:text-obsidian py-2">Pricing</a>
          <a href="/blog" class="font-body text-sm text-slate hover:text-obsidian py-2">Blog</a>
          <a href="/about" class="font-body text-sm text-slate hover:text-obsidian py-2">About</a>
          <a href="/book" class="btn-primary text-xs text-center">Book a Session</a>
        </div>
      </div>
    </nav>

    <main class="flex-1 pt-16 lg:pt-20">
      <slot />
    </main>

    <footer class="bg-obsidian text-bone/70">
      <div class="container-wide py-16 lg:py-20">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
          <div>
            <p class="font-display font-bold text-bone text-lg mb-4">Matt Guerra</p>
            <p class="font-body text-sm leading-relaxed">
              Commercial photography in Houston, Texas.
              Menu, product, portrait, and event photography.
            </p>
          </div>
          <div>
            <p class="label text-bone/40 mb-4">Navigation</p>
            <div class="flex flex-col gap-2">
              <a href="/work" class="font-body text-sm hover:text-bone">Work</a>
              <a href="/pricing" class="font-body text-sm hover:text-bone">Pricing</a>
              <a href="/blog" class="font-body text-sm hover:text-bone">Blog</a>
              <a href="/about" class="font-body text-sm hover:text-bone">About</a>
              <a href="/contact" class="font-body text-sm hover:text-bone">Contact</a>
            </div>
          </div>
          <div>
            <p class="label text-bone/40 mb-4">Connect</p>
            <div class="flex flex-col gap-2">
              <a href="mailto:matthewrguerra@gmail.com" class="font-body text-sm hover:text-bone">Email</a>
              <a href="#" class="font-body text-sm hover:text-bone">Instagram</a>
              <a href="#" class="font-body text-sm hover:text-bone">LinkedIn</a>
            </div>
          </div>
        </div>
        <div class="mt-16 pt-8 border-t border-bone/10 flex flex-col md:flex-row justify-between items-center gap-4">
          <p class="font-mono text-xs text-bone/30">
            &copy; {new Date().getFullYear()} Matt Guerra Photography. All rights reserved.
          </p>
          <p class="font-mono text-xs text-bone/30">
            Houston, TX
          </p>
        </div>
      </div>
    </footer>

    <script>
      const toggle = document.getElementById('mobile-menu-toggle');
      const menu = document.getElementById('mobile-menu');
      toggle?.addEventListener('click', () => {
        menu?.classList.toggle('hidden');
      });
    </script>
  </body>
</html>
