---
interface Props {
  title: string;
  slug: string;
  coverImage?: string;
  category?: string;
  client?: string;
}

const { title, slug, coverImage, category, client } = Astro.props;
---

<a href={`/work/${slug}`} class="group block">
  <div class="aspect-[4/3] overflow-hidden bg-warm-gray/10 mb-4">
    {coverImage ? (
      <img
        src={coverImage}
        alt={title}
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        loading="lazy"
      />
    ) : (
      <div class="w-full h-full flex items-center justify-center">
        <span class="label">No image</span>
      </div>
    )}
  </div>
  <div class="flex items-start justify-between gap-4">
    <div>
      <h3 class="font-display font-semibold text-obsidian group-hover:text-copper transition-colors">
        {title}
      </h3>
      {client && <p class="font-body text-sm text-warm-gray mt-1">{client}</p>}
    </div>
    {category && (
      <span class="label shrink-0 mt-1">{category}</span>
    )}
  </div>
</a>
