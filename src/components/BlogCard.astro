---
interface Props {
  title: string;
  slug: string;
  excerpt?: string;
  coverImage?: string;
  date?: string;
  readingTime?: number;
  category?: string;
}

const { title, slug, excerpt, coverImage, date, readingTime, category } = Astro.props;

const formattedDate = date ? new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}) : '';
---

<a href={`/blog/${slug}`} class="group block">
  {coverImage && (
    <div class="aspect-[16/9] overflow-hidden bg-warm-gray/10 mb-4">
      <img
        src={coverImage}
        alt={title}
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        loading="lazy"
      />
    </div>
  )}
  <div class="flex items-center gap-3 mb-2">
    {category && <span class="label">{category}</span>}
    {formattedDate && <span class="label">{formattedDate}</span>}
    {readingTime && <span class="label">{readingTime} min read</span>}
  </div>
  <h3 class="heading-3 group-hover:text-copper transition-colors mb-2">{title}</h3>
  {excerpt && <p class="font-body text-sm text-warm-gray leading-relaxed line-clamp-2">{excerpt}</p>}
</a>
