---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact"
  description="Book a photography session with Matt Guerra Photography in Houston, Texas."
>
  <section class="section-padding">
    <div class="container-wide">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24">
        <div>
          <p class="label text-copper mb-3">Contact</p>
          <h1 class="heading-1 mb-6">Let's work<br />together.</h1>
          <p class="body-large text-warm-gray mb-10 max-w-md">
            Fill out the booking form and I'll get back to you within 24 hours.
            Or reach out directly if you prefer.
          </p>

          <div class="space-y-6">
            <div>
              <p class="label mb-2">Email</p>
              <a href="mailto:matthewrguerra@gmail.com" class="font-body text-obsidian hover:text-copper">
                matthewrguerra@gmail.com
              </a>
            </div>
            <div>
              <p class="label mb-2">Based in</p>
              <p class="font-body text-obsidian">Houston, Texas</p>
            </div>
            <div>
              <p class="label mb-2">Response time</p>
              <p class="font-body text-obsidian">Within 24 hours</p>
            </div>
          </div>
        </div>

        <div>
          <!-- HoneyBook Embed Placeholder -->
          <div class="bg-white border border-warm-gray/20 p-8 lg:p-10 min-h-[500px] flex items-center justify-center">
            <div class="text-center">
              <p class="label mb-4">HoneyBook Booking Form</p>
              <p class="font-body text-sm text-warm-gray max-w-xs">
                Your HoneyBook booking form embed will go here. Replace this placeholder with the HoneyBook embed script.
              </p>
              <div class="mt-6 p-4 bg-bone font-mono text-xs text-warm-gray">
                &lt;!-- Paste HoneyBook embed code here --&gt;
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
